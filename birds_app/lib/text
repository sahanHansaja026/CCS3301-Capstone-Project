padding: const EdgeInsets.all(16),
              child: Column(
                children: [
                  Image.network(bird['images'][0]),

                  const SizedBox(height: 20),

                  Text(bird['name'], style: const TextStyle(fontSize: 22)),

                  Text(bird['scientific_name'] ?? ""),

                  const SizedBox(height: 10),

                  Text(bird['short_description'] ?? ""),

                  const SizedBox(height: 30),

                  // 🎵 AUDIO PLAYER
                  if (soundUrl != null && soundUrl != "")
                    ElevatedButton.icon(
                      onPressed: () {
                        isPlaying ? stopSound() : playSound(soundUrl);
                      },
                      icon: Icon(isPlaying ? Icons.stop : Icons.play_arrow),
                      label: Text(isPlaying ? "Stop Sound" : "Play Bird Sound"),
                    )
                  else
                    const Text("No sound available"),
                ],
              ),